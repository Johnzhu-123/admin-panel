{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "incremental": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "jest", "@testing-library/jest-dom"]
  },
  "include": ["next-env.d.ts", "**/__tests__/**/*.ts", "**/__tests__/**/*.tsx", "**/*.test.ts", "**/*.test.tsx"],
  "exclude": ["node_modules", "dist", "build"]
}

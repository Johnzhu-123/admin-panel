{
  "name": "md2ppt",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "electron:dev": "cross-env ELECTRON_DEV_URL=http://localhost:3000 ELECTRON_DESKTOP=1 concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:build": "npm run build && electron-builder --win",
    "db:init": "node scripts/init-database.mjs",
    "db:check": "node scripts/check-terms-acceptance.mjs",
    "test:terms": "node scripts/test-terms-acceptance.mjs",
    "test:usage": "node scripts/test-usage-tracking.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.5",
    "@clerk/nextjs": "^6.36.8",
    "@google/genai": "^1.34.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@vercel/postgres": "^0.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "jspdf": "^4.0.0",
    "jszip": "3.10.1",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.11.0",
    "next": "^15.3.1",
    "pdfjs-dist": "^5.4.530",
    "pptxgenjs": "3.12.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^2.8.0",
    "svix": "^1.84.1",
    "tailwind-merge": "^2.0.0",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.1",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.1.2",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.md2ppt.desktop",
    "productName": "md2ppt",
    "npmRebuild": false,
    "files": [
      "electron/**",
      "python/**",
      "app/**",
      "components/**",
      "lib/**",
      "public/**",
      ".next/**",
      "middleware.ts",
      "next.config.mjs",
      "package.json",
      "node_modules/**"
    ],
    "asar": true,
    "asarUnpack": [
      "python/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}

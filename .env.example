NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/
CLERK_AFTER_SIGN_UP_URL=/

# Production security stores and secret encryption (never commit real values)
POSTGRES_URL=postgres://replace_me
POSTGRES_URL_NON_POOLING=postgres://replace_me_direct
ADMIN_PASSWORD=replace_with_at_least_16_random_characters
ADMIN_TRUST_PROXY_HEADERS=0
SECURITY_STRICT_CSP_MODE=report-only
BUILT_IN_ENCRYPTION_KEY=replace_with_32_byte_base64_key
BUILT_IN_ENCRYPTION_KEY_ID=primary-2026

# ===========================================
# 内置API服务配置 - 第三方OpenAI兼容API
# ===========================================

# 第三方API密钥（必需）
GEMINI_BUILT_IN_API_KEY=sk-1234567890abcdef

# 第三方API基础URL（必需）
GEMINI_BUILT_IN_BASE_URL=https://your-api-provider.com/v1

# 服务配置
BUILT_IN_SERVICE_ENABLED=true
BUILT_IN_SERVICE_NAME="第三方Gemini服务"

# ===========================================
# MinerU 内置云端服务（文档解析）
# ===========================================
# 必需：mineru.net 官方 Bearer Token（admin 名下，由所有授权用户共用）
MINERU_BUILT_IN_API_TOKEN=

# 可选：mineru.net 主域，默认 https://mineru.net
# MINERU_BUILT_IN_BASE_URL=https://mineru.net

# 可选：业务参数默认值（客户端 UI 初始填充，用户可在本地 override）
# MINERU_DEFAULT_MODEL_VERSION=vlm           # vlm | pipeline | MinerU-HTML | auto
# MINERU_DEFAULT_LANGUAGE=ch                 # ch | en | japan | korean
# MINERU_DEFAULT_ENABLE_FORMULA=true
# MINERU_DEFAULT_ENABLE_TABLE=true
# MINERU_DEFAULT_IS_OCR=false
# MINERU_DEFAULT_EXTRA_FORMATS=              # 逗号分隔，例：docx,html,latex

# 授权用户（必需 - JSON格式）
AUTHORIZED_USERS='[{"userId":"user@example.com","email":"user@example.com","name":"用户名","status":"active","permissions":{"canUseBuiltInServices":true,"allowedServices":["gemini-built-in"],"quotaLimits":{"dailyRequests":100,"monthlyRequests":2000,"concurrentRequests":5},"grantedAt":"2024-01-01T00:00:00.000Z","grantedBy":"admin"}}]'

# 安全配置（可选）
MAX_REQUESTS_PER_MINUTE=15
MAX_REQUESTS_PER_HOUR=150
MAX_REQUESTS_PER_DAY=1000
MAX_PROMPT_LENGTH=8000
MAX_CONCURRENT_REQUESTS=3

# 性能配置（可选）
CACHE_MAX_SIZE=52428800
CACHE_MAX_ENTRIES=500
CACHE_TTL=600000

# 监控配置（可选）
LOG_LEVEL=info
ENABLE_PERFORMANCE_MONITORING=true
